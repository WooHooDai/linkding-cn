#: bookmarks/templates/settings/general.html:30
#: bookmarks/templates/shared/language_switcher.html:7
msgid "Language"
msgstr "语言"

#: bookmarks/templates/settings/general.html:33
msgid "Choose the interface language. After saving, the selected language takes precedence over the browser language."
msgstr "选择界面语言。保存后，所选语言将优先于浏览器语言。"

#: bookmarks/templates/settings/general.html:37
msgid "Theme"
msgstr "主题"

#: bookmarks/templates/settings/general.html:40
msgid "Choose a light or dark theme, or automatically follow your system setting."
msgstr "手动选择明暗主题，或基于系统设置自动切换。"

#: bookmarks/templates/settings/general.html:44
msgid "Bookmark date format"
msgstr "书签日期格式"

#: bookmarks/templates/settings/general.html:47
msgid "Show bookmark dates as relative dates, absolute dates, or hide them entirely."
msgstr "书签日期显示为相对日期、绝对日期，或隐藏。"

#: bookmarks/templates/settings/general.html:51
msgid "Bookmark description"
msgstr "书签描述"

#: bookmarks/templates/settings/general.html:54
msgid "Show bookmark descriptions and tags in one line, or render them in separate blocks."
msgstr "书签描述与标签同行显示，或另起分块显示。"

#: bookmarks/templates/settings/general.html:58
msgid "Bookmark description max lines"
msgstr "书签描述最大行数"

#: bookmarks/templates/settings/general.html:61
msgid "Limit how many lines are shown for bookmark descriptions."
msgstr "限制书签描述显示的最大行数。"

#: bookmarks/templates/settings/general.html:67
msgid "Show bookmark URL"
msgstr "显示书签 URL"

#: bookmarks/templates/settings/general.html:70
msgid "Display the bookmark URL below the title."
msgstr "在书签标题下显示书签 URL。"

#: bookmarks/templates/settings/general.html:76
msgid "Show notes permanently"
msgstr "永久显示笔记"

#: bookmarks/templates/settings/general.html:79
msgid "Keep notes expanded by default instead of toggling them individually."
msgstr "默认展开笔记，而不是逐条手动切换。"

#: bookmarks/templates/settings/general.html:80
msgid "You can also temporarily show all notes with the keyboard shortcut"
msgstr "你也可以通过键盘快捷键临时显示全部笔记"

#: bookmarks/templates/settings/general.html:84
msgid "Bookmark actions"
msgstr "书签动作"

#: bookmarks/templates/settings/general.html:102
msgid "Choose which actions are shown for each bookmark."
msgstr "选择每条书签要显示的动作。"

#: bookmarks/templates/settings/general.html:106
msgid "Open bookmarks in"
msgstr "书签打开方式"

#: bookmarks/templates/settings/general.html:109
msgid "Open bookmarks in the current page or in a new page."
msgstr "在当前页面或新页面中打开书签。"

#: bookmarks/templates/settings/general.html:113
msgid "Items per page"
msgstr "每页书签数量"

#: bookmarks/templates/settings/general.html:121
msgid "Choose how many bookmarks are shown on each page."
msgstr "选择每页显示多少条书签。"

#: bookmarks/templates/settings/general.html:127
msgid "Sticky search bar"
msgstr "粘性搜索栏"

#: bookmarks/templates/settings/general.html:130
msgid "Keep the search and action controls pinned to the top while you scroll."
msgstr "滚动时将搜索栏和操作区固定在顶部。"

#: bookmarks/templates/settings/general.html:136
msgid "Sticky pagination"
msgstr "粘性分页"

#: bookmarks/templates/settings/general.html:139
msgid "Keep the pagination controls pinned to the bottom while you scroll."
msgstr "滚动时将分页控件固定在底部。"

#: bookmarks/templates/settings/general.html:145
msgid "Sticky side panel"
msgstr "侧边栏跟随"

#: bookmarks/templates/settings/general.html:148
msgid "Keep the side panel visible while scrolling on wider screens."
msgstr "在较宽屏幕上滚动时保持侧边栏可见。"

#: bookmarks/templates/settings/general.html:149
msgid "This option is automatically disabled when the side panel is collapsed."
msgstr "当侧边栏折叠时，此选项会自动禁用。"

#: bookmarks/templates/settings/general.html:155
msgid "Collapse side panel"
msgstr "折叠侧边栏"

#: bookmarks/templates/settings/general.html:158
msgid "Collapse the side panel by default to give the bookmark list more room."
msgstr "默认折叠侧边栏，为书签列表留出更多空间。"

#: bookmarks/templates/settings/general.html:164
msgid "Hide bundles"
msgstr "隐藏过滤器"

#: bookmarks/templates/settings/general.html:167
msgid "Hide the bundles panel in the sidebar if you do not use bundles."
msgstr "如果你不使用过滤器，可在侧边栏中隐藏过滤器面板。"

#: bookmarks/templates/settings/general.html:171
msgid "Tag search"
msgstr "标签搜索"

#: bookmarks/templates/settings/general.html:174
msgid "In strict mode, tags must be prefixed with a hash character (#)."
msgstr "在 Strict 模式下，标签必须带有井号前缀（#）。"

#: bookmarks/templates/settings/general.html:175
msgid "In lax mode, tags can also be found without the hash character."
msgstr "在 Lax 模式下，没有井号前缀的标签也能被搜索到。"

#: bookmarks/templates/settings/general.html:176
msgid "Without the hash character, tags are harder to distinguish from ordinary search terms, so unrelated results may also match."
msgstr "如果没有井号前缀，标签与普通关键词更难区分，因此也可能匹配到无关结果。"

#: bookmarks/templates/settings/general.html:180
msgid "Tag grouping"
msgstr "标签聚合"

#: bookmarks/templates/settings/general.html:183
msgid "In alphabetical mode, tags are grouped by the first letter."
msgstr "在 Alphabetical 模式下，标签会按首字母分组。"

#: bookmarks/templates/settings/general.html:184
msgid "If disabled, tags are shown without grouping."
msgstr "关闭后，标签将不进行分组显示。"

#: bookmarks/templates/settings/general.html:190
#: bookmarks/templates/settings/general.html:192
msgid "Auto Tagging"
msgstr "自动标签"

#: bookmarks/templates/settings/general.html:198
msgid "Automatically add tags to bookmarks based on custom rules."
msgstr "根据自定义规则为书签自动添加标签。"

#: bookmarks/templates/settings/general.html:199
msgid "Each line is one rule that maps a URL to one or more tags. For example:"
msgstr "每行是一条规则，将 URL 映射到一个或多个标签。例如："

#: bookmarks/templates/settings/general.html:207
msgid "Enable Favicons"
msgstr "启用 Favicons"

#: bookmarks/templates/settings/general.html:210
msgid "Automatically load favicons for bookmarked websites and display them next to each bookmark."
msgstr "自动为已收藏的网站加载 favicon，并显示在每条书签旁边。"

#: bookmarks/templates/settings/general.html:211
msgid "Enabling this feature downloads all missing favicons in the background."
msgstr "启用后会在后台下载所有缺失的 favicon。"

#: bookmarks/templates/settings/general.html:212
msgid "By default, this feature uses a Google service to fetch favicons."
msgstr "默认情况下，此功能使用 Google 的服务获取 favicon。"

#: bookmarks/templates/settings/general.html:213
msgid "If you prefer a different provider, check the"
msgstr "如果你更喜欢其他提供方，请查看"

#: bookmarks/templates/settings/general.html:213
msgid "options documentation"
msgstr "配置文档"

#: bookmarks/templates/settings/general.html:216
msgid "Refresh Favicons"
msgstr "刷新 Favicons"

#: bookmarks/templates/settings/general.html:222
msgid "Enable Preview Images"
msgstr "启用预览图"

#: bookmarks/templates/settings/general.html:225
msgid "Automatically load preview images for bookmarked websites and display them next to each bookmark."
msgstr "自动为已收藏的网站加载预览图，并显示在每条书签旁边。"

#: bookmarks/templates/settings/general.html:226
msgid "Enabling this feature downloads missing preview images in the background."
msgstr "启用后会在后台下载缺失的预览图。"

#: bookmarks/templates/settings/general.html:230
msgid "Internet Archive integration"
msgstr "Internet Archive 集成"

#: bookmarks/templates/settings/general.html:233
msgid "When enabled, snapshots of bookmarked websites are automatically created on the Internet Archive Wayback Machine."
msgstr "启用后，会自动在 Internet Archive Wayback Machine 上为已收藏的网站创建快照。"

#: bookmarks/templates/settings/general.html:234
msgid "This helps preserve websites as they looked when you bookmarked them."
msgstr "这有助于保留网站在你收藏时的样貌。"

#: bookmarks/templates/settings/general.html:235
msgid "Please consider supporting the Internet Archive if you rely on this feature."
msgstr "如果你依赖此功能，请考虑支持 Internet Archive。"

#: bookmarks/templates/settings/general.html:241
msgid "Enable bookmark sharing"
msgstr "启用书签分享"

#: bookmarks/templates/settings/general.html:244
msgid "Allow bookmarks to be shared with other users and allow viewing bookmarks shared by others."
msgstr "允许将书签分享给其他用户，并允许查看其他人分享的书签。"

#: bookmarks/templates/settings/general.html:250
msgid "Enable public bookmark sharing"
msgstr "启用公开书签分享"

#: bookmarks/templates/settings/general.html:253
msgid "Make shared bookmarks visible without requiring a login."
msgstr "无需登录即可查看已分享书签。"

#: bookmarks/templates/settings/general.html:254
msgid "Anyone who can access this instance can then browse the"
msgstr "任何可访问本实例的人随后都可以浏览"

#: bookmarks/templates/settings/general.html:254
msgid "shared bookmarks page"
msgstr "已分享书签页面"

#: bookmarks/templates/settings/general.html:261
msgid "Automatically create HTML snapshots"
msgstr "自动创建 HTML 快照"

#: bookmarks/templates/settings/general.html:264
msgid "Automatically create HTML snapshots when adding new bookmarks."
msgstr "添加新书签时自动创建 HTML 快照。"

#: bookmarks/templates/settings/general.html:265
msgid "If disabled, snapshots can still be created manually from the bookmark details view."
msgstr "即使关闭，也仍可以在书签详情页手动创建快照。"

#: bookmarks/templates/settings/general.html:267
msgid "Create missing HTML snapshots"
msgstr "创建缺失的 HTML 快照"

#: bookmarks/templates/settings/general.html:273
msgid "Create bookmarks as unread by default"
msgstr "默认将新书签标记为未读"

#: bookmarks/templates/settings/general.html:276
msgid "Set newly created bookmarks to unread by default."
msgstr "默认将新建书签标记为未读。"

#: bookmarks/templates/settings/general.html:282
msgid "Create bookmarks as shared by default"
msgstr "默认将新书签标记为已分享"

#: bookmarks/templates/settings/general.html:285
msgid "Set newly created bookmarks to shared by default."
msgstr "默认将新建书签标记为已分享。"

#: bookmarks/templates/settings/general.html:291
#: bookmarks/templates/settings/general.html:293
msgid "Custom CSS"
msgstr "自定义 CSS"

#: bookmarks/templates/settings/general.html:299
msgid "Add custom CSS that is loaded for your profile."
msgstr "为你的个人配置添加自定义 CSS。"

#: bookmarks/templates/settings/general.html:305
#: bookmarks/templates/settings/general.html:307
msgid "Custom domain normalization"
msgstr "自定义域名归一化"

#: bookmarks/templates/settings/general.html:313
msgid "Configure one root domain per line."
msgstr "每行配置一个根域名。"

#: bookmarks/templates/settings/general.html:314
msgid "All matching subdomains are normalized to the configured root domain, which affects favicon-based domain filters."
msgstr "所有匹配的子域名都会归一化为所配置的根域名，这会影响基于 favicon 的域名筛选。"

#: bookmarks/templates/settings/general.html:315
msgid "Example: setting example.com normalizes a.example.com and b.example.com to example.com."
msgstr "例如：设置 example.com 后，a.example.com 和 b.example.com 会被归一化为 example.com。"

#: bookmarks/templates/settings/general.html:316
msgid "If you also set a.example.com explicitly, that subdomain remains separate while other subdomains still normalize to example.com."
msgstr "如果你同时显式设置 a.example.com，那么该子域名会保持独立，其他子域名仍会归一化为 example.com。"

#: bookmarks/templates/settings/general.html:327
msgid "Global settings"
msgstr "全局设置"

#: bookmarks/templates/settings/general.html:331
msgid "Landing page"
msgstr "默认首页"

#: bookmarks/templates/settings/general.html:334
msgid "Choose which page unauthenticated users are redirected to when they open the root URL."
msgstr "选择未登录用户打开根路径时将被重定向到哪个页面。"

#: bookmarks/templates/settings/general.html:338
msgid "Guest user profile"
msgstr "访客用户配置"

#: bookmarks/templates/settings/general.html:341
msgid "Choose which profile is used for anonymous visitors viewing publicly shared bookmarks."
msgstr "选择匿名访客查看公开分享书签时使用的用户配置。"

#: bookmarks/templates/settings/general.html:347
msgid "Enable hover prefetching for internal links"
msgstr "启用内部链接悬停预取"

#: bookmarks/templates/settings/general.html:350
msgid "Prefetch internal links when users hover over them. This improves perceived speed, but increases server load."
msgstr "用户悬停在内部链接上时预取目标页面。这样可以提升体感速度，但也会增加服务器负载。"

#: bookmarks/templates/settings/general.html:362
msgid "Import"
msgstr "导入"

#: bookmarks/templates/settings/general.html:363
msgid "Import bookmarks and tags from a Netscape HTML file. Existing bookmarks are updated when the imported URL already exists."
msgstr "从 Netscape HTML 文件导入书签和标签。如果导入的 URL 已存在，则更新现有书签。"

#: bookmarks/templates/settings/general.html:369
msgid "Import public bookmarks as shared bookmarks"
msgstr "将公开书签导入为已分享书签"

#: bookmarks/templates/settings/general.html:372
msgid "If the imported file marks bookmarks as public or private using the PRIVATE attribute, non-private bookmarks are imported as shared bookmarks and private bookmarks remain private."
msgstr "如果导入文件使用 PRIVATE 属性标记书签的公开或私有状态，则非私有书签会作为已分享书签导入，私有书签保持私有。"

#: bookmarks/templates/settings/general.html:378
msgid "Upload"
msgstr "上传"

#: bookmarks/templates/settings/general.html:385
msgid "Export"
msgstr "导出"

#: bookmarks/templates/settings/general.html:386
msgid "Export all bookmarks as a Netscape HTML file."
msgstr "将全部书签导出为 Netscape HTML 文件。"

#: bookmarks/templates/settings/general.html:387
msgid "Download (.html)"
msgstr "下载（.html）"

#: bookmarks/templates/settings/general.html:398
msgid "About"
msgstr "关于"

#: bookmarks/templates/settings/general.html:402
